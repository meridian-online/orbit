{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "orbit session prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "orbit session start",
            "type": "command"
          },
          {
            "command": "orbit session prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "orbit session distill && rm -f .orbit/.session-id",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
